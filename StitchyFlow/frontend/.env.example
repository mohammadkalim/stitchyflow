# API base (no trailing slash). Production / remote APIs: set this.
# REACT_APP_API_URL=https://your-api.example.com/api/v1
#
# Local backend: on CRA dev (:3000), http://127.0.0.1:5000/api/v1 (or localhost:5000) is auto-rewritten to
# same-origin /api/v1 so the browser uses setupProxy.js — avoids 404 when another app is on :5000.
# To force the browser to call :5000 directly anyway: REACT_APP_DIRECT_API=1
# Proxy target (default http://127.0.0.1:5000): REACT_APP_PROXY_TARGET=http://127.0.0.1:5000

# Splash duration in ms (full page load / refresh). Values below 800 are ignored; default 5000.
REACT_APP_SPLASH_DURATION_MS=5000
