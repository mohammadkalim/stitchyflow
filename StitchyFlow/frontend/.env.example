# API base (no trailing slash). If set, it is always used — recommended if you see 404 on /api/v1/... from the dev server:
# REACT_APP_API_URL=http://127.0.0.1:5000/api/v1
# Leave unset to use same-origin /api/v1 on :3000 (proxied to REACT_APP_PROXY_TARGET or http://127.0.0.1:5000 via src/setupProxy.js).
# Production example:
# REACT_APP_API_URL=https://your-api.example.com/api/v1

# Splash duration in ms (full page load / refresh). Values below 800 are ignored; default 5000.
REACT_APP_SPLASH_DURATION_MS=5000
