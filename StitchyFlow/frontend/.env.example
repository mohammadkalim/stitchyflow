# Optional. Leave unset in local dev to use the CRA proxy (see package.json "proxy") → /api/v1 → http://localhost:5000/api/v1
# For production or direct API calls, set the full base URL (no trailing slash):
# REACT_APP_API_URL=https://your-api.example.com/api/v1

# Splash duration in ms (full page load / refresh). Values below 800 are ignored; default 5000.
REACT_APP_SPLASH_DURATION_MS=5000
