# Copy to `.env` and adjust. See root README for full backend configuration.

# Default maximum tailor-owned shops per account (integer >= 1).
TAILOR_MAX_BUSINESSES=1

# Optional per-email limits (comma-separated, case-insensitive): email:max,email2:max2
# Also accepts email=max segments if using alias env TAILOR_SHOP_CAP_OVERRIDES.
# Example — allow two shops for a specific tailor:
TAILOR_MAX_BUSINESSES_OVERRIDES=markhubstore98@gmail.com:2
