# Copy to `.env` and adjust. Never commit real secrets.
#
# Tailor dashboard — how many businesses (shops) one tailor account may create.
# Default is 1 if unset.
# TAILOR_DEFAULT_MAX_SHOPS=1
#
# Per-email caps (case-insensitive). Use = between email and count.
# Multiple entries: separate with ; or ,
# Example: allow markhubstore98@gmail.com to create2 shops:
TAILOR_SHOP_CAP_OVERRIDES=markhubstore98@gmail.com=2
#
# Alternative: JSON object
# TAILOR_SHOP_CAP_OVERRIDES={"markhubstore98@gmail.com":2}
